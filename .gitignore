//.gitignore (raíz)
# Dependencies
node_modules/
**/node_modules/
package-lock.json
**/package-lock.json

# Environment Variables
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.production
.env copy

# Build outputs
dist/
frontend/dist/
frontend/.vite/
backend/.vite/
.vite

# Logs
*.log
npm-debug.log*
backend/backend.log

# OS Files
.DS_Store
.DS_Store?
._*
Thumbs.db

# IDE
.idea
.vscode/*
!.vscode/extensions.json

# Development files
scripts/dev/
frontend/dev-pages/
**/styleguide/

# Temporary
*.tmp
*.temp
*.bak
*.swp
*~

# Snapshots (dev tool)
snapshots/*.json
snapshots/*.txt

# Development docs (mantener docs principales)
docs/development/archives/
docs/drafts/
*.draft.md

# Copilot temp
.copilot-temp
.qodo/



